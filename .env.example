# Mandio Environment Variables
# Copy this file to .env.local and fill in values as needed.

# ─── Authentication (Auth.js v5 + Google OAuth) ─────────────────────────────
# Required for session-based auth.
# Generate AUTH_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Google OAuth credentials from https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: http://localhost:3000/api/auth/callback/google
#
# AUTH_SECRET=your-generated-secret-here
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
# ALLOWED_EMAILS=user@example.com,user2@example.com
#   (comma-separated; leave commented out or unset to deny all users by default)
# AUTH_ALLOW_ALL_USERS=true
#   (development-only: set to "true" to allow any Google account without
#    explicit ALLOWED_EMAILS. ⚠️  IGNORED in production (NODE_ENV=production).
#    Only effective when NODE_ENV is not 'production'.)

# ─── Webhook trigger (POST /api/webhooks) ───────────────────────────────────
# Shared HMAC-SHA256 secret for authenticating incoming webhook calls.
# Leave unset or empty to disable the webhook endpoint (returns 503).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# MANDIO_WEBHOOK_SECRET=your-generated-secret-here
