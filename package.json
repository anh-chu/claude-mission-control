{
	"name": "mandio",
	"version": "0.15.0",
	"license": "AGPL-3.0-only",
	"type": "module",
	"bin": {
		"mctl": "./bin/cli.js",
		"mandio": "./bin/cli.js"
	},
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"build:daemon": "tsx scripts/build-daemon.ts",
		"build:cli": "tsx scripts/build-cli.ts && node --check bin/cli.js",
		"build:all": "pnpm build && pnpm build:daemon && pnpm build:cli && pnpm copy:standalone-assets",
		"copy:standalone-assets": "tsx scripts/copy-standalone-assets.ts",
		"prepublishOnly": "pnpm build:all",
		"start": "next start",
		"lint": "next lint",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "pnpm tsc --noEmit && pnpm lint",
		"verify": "pnpm check && pnpm build && pnpm test",
		"gen:context": "npx tsx scripts/generate-context.ts",
		"cleanup:uploads": "npx tsx scripts/cleanup-uploads.ts",
		"daemon:start": "npx tsx scripts/daemon/index.ts start",
		"daemon:stop": "npx tsx scripts/daemon/index.ts stop",
		"daemon:status": "npx tsx scripts/daemon/index.ts status",
		"knip": "knip"
	},
	"files": [
		"bin/cli.js",
		"dist/",
		".next/standalone/",
		".next/static/",
		"public/",
		"artifacts/",
		"package.json",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.114",
		"@dnd-kit/core": "^6.3.1",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.8",
		"async-mutex": "^0.5.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"gray-matter": "^4.0.3",
		"lucide-react": "^0.525.0",
		"nanoid": "^5.1.6",
		"next": "16.2.4",
		"next-themes": "^0.4.6",
		"node-cron": "^4.2.1",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.3.0",
		"tree-kill": "^1.2.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.3",
		"@types/node": "^22.15.0",
		"@types/node-cron": "^3.0.11",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"autoprefixer": "^10.4.20",
		"esbuild": "^0.28.0",
		"eslint": "^9.0.0",
		"eslint-config-next": "16.2.4",
		"knip": "^6.7.0",
		"lefthook": "^2.1.6",
		"postcss": "^8.5.6",
		"postcss-load-config": "^6.0.1",
		"tailwindcss": "^3.4.17",
		"tsx": "^4.21.0",
		"typescript": "^5.8.0",
		"vitest": "^4.0.18"
	},
	"pnpm": {
		"overrides": {
			"@types/react": "19.2.14",
			"@types/react-dom": "19.2.3"
		}
	}
}
