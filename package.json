		"start": "next start",
		"lint": "next lint",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "pnpm tsc --noEmit && pnpm lint",
		"verify": "pnpm check && pnpm build && pnpm test",
		"gen:context": "npx tsx scripts/generate-context.ts",
		"cleanup:uploads": "npx tsx scripts/cleanup-uploads.ts",
		"knip": "knip"
	},
