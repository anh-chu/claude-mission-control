		"dev": "next dev",
		"build": "next build",
		"build:scripts": "tsx scripts/build-scripts.ts",
		"build:cli": "tsx scripts/build-cli.ts && node --check bin/cli.js",
		"build:all": "pnpm build && pnpm build:scripts && pnpm build:cli && pnpm copy:standalone-assets",
